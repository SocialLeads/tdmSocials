NODE_ENV=production
PORT=4000

# Database (Docker service)
DB_HOST=db
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=
JWT_RESET_SECRET=
ACCESS_TOKEN_EXPIRY=30m
REFRESH_TOKEN_EXPIRY=15d

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP (private mail server)
SMTP_HOST=smtp.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@tdmsocials.nl
SMTP_FROM_NAME=TDM Socials

# Admin
ADMIN_CONTACT_EMAIL=info@tdmsocials.nl
FRONTEND_DOMAIN=https://tdmsocials.nl,https://www.tdmsocials.nl

# Cron (default: 8 AM daily)
CRON_SCHEDULE=0 8 * * *

# Image generation (DALL-E)
DALL_E_MODEL=dall-e-3
DALL_E_QUALITY=standard
IMAGE_STORAGE_PATH=/app/public/generated
PUBLIC_IMAGE_BASE_URL=https://tdmsocials.nl/generated
IMAGE_RETENTION_DAYS=365

FAL_API_KEY=your_fal_ai_key_here
IMAGE_PROVIDER=flux
