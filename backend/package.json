{
  "name": "backend-api",
  "version": "1.0.0",
  "description": "NestJS app with PostgreSQL and TypeORM",
  "scripts": {
    "start": "node dist/main",
    "start:stack:local": "docker compose -f docker-compose.dev.yml up -d redis db",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:local": "cross-env NODE_ENV=local nest start --watch",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typeorm": "dotenv -e .env -- typeorm-ts-node-commonjs",
    "migrate:run": "cross-env TS_NODE_TRANSPILE_ONLY=1 ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:run -d src/config/database.config.ts",
    "db:seed:data": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r dotenv/config -r ts-node/register -r tsconfig-paths/register src/utils/seeder.ts",
    "migrate:run:local": "cross-env NODE_ENV=local npm run migrate:run",
    "db:seed:data:local": "cross-env NODE_ENV=local npm run db:seed:data",
    "db:reset:local": "cross-env NODE_ENV=local ./reset-db.sh",
    "db:reset": "./reset-db.sh",
    "create-admin": "node scripts/create-admin-user.js",
    "jwt": "node scripts/generate-jwt.js",
    "dev-reset": "./scripts/dev-reset.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.2",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "nest-winston": "^1.10.2",
    "nodemailer": "^6.10.1",
    "openai": "^5.20.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "puppeteer": "^24.9.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.26",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.1",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.0.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
